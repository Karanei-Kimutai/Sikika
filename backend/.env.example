# Database connection
DB_HOST=localhost
DB_PORT=3306
DB_NAME=CSProjectDB
DB_USER=root
DB_PASSWORD=yourpassword

# Frontend host allowed by CORS
FRONTEND_ORIGIN=http://localhost:5173

# Runtime
NODE_ENV=production
PORT=5000

# Local/dev behavior
SKIP_SMS_IN_DEV=false
# Optional schema controls
DB_SYNC_ALTER=false          # set true once to apply alter-mode sync (risky on large DBs)
ENABLE_SCHEMA_COMPAT=true    # set false to skip boot-time schema reconciliation (emergency rollback)

# Africa's Talking SMS provider
AFRICASTALKING_API_KEY=your_africastalking_api_key
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_SENDER_ID=

# JWT signing key used by auth middleware and token issuance
JWT_SECRET=replace_with_a_long_random_secret

# Cloudinary credentials used by:
# - incident evidence uploads (private/authenticated assets)
# - support resource uploads (publicly readable library assets)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
